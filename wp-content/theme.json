{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"custom": false,
			"customGradient": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"gradients": [],
			"palette": [
				{
					"slug": "dos-blue",
					"color": "#000084",
					"name": "DOS Blue"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				},
				{
					"slug": "gray",
					"color": "#808080",
					"name": "Gray"
				},
				{
					"slug": "dark-gray",
					"color": "#333333",
					"name": "Dark Gray"
				},
				{
					"slug": "maroon",
					"color": "#800000",
					"name": "Maroon"
				}
			]
		},
		"typography": {
			"customFontSize": false,
			"letterSpacing": false,
			"textDecoration": false,
