	"styles": {
		"color": {
			"background": "#000084",
			"text": "#ffffff"
		},
		"typography": {
			"fontFamily": "monospace",
			"fontSize": "18px"
		},
		"elements": {
			"link": {
				"color": {
					"text": "#ffffff"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "monospace"
				}
			}
		}
